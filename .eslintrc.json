{
  "extends": ["next/core-web-vitals", "next/typescript"],
  "rules": {
    "no-restricted-imports": [
      "error",
      {
        "paths": [
          {
            "name": "next/link",
            "message": "Für interne Links { Link } aus @/i18n/navigation verwenden, damit das Locale-Präfix erhalten bleibt."
          }
        ]
      }
    ]
  },
  "overrides": [
    {
      "files": ["components/ui/**/*"],
      "rules": {
        "react/react-in-jsx-scope": "off",
        "no-unused-vars": "off"
        // Add other rules you want to disable or modify for this folder
      }
    }
  ]
}
